streamlines
{
    type            streamlines;

    libs            ("libfieldFunctionObjects.so");

    // Output every
    writeControl    writeTime;

    // Write format
    setFormat       vtk;

    // Перемещайтесь вперед (+U) или назад (-U), или и вперед, и назад.
    direction       forward;

    // Названия полей для выборки. Должны содержать указанное выше поле скоростей!
    fields (p U k);

    // Частицы могут перемещаться на несколько шагов, прежде чем будут удалены.
    lifeTime        10000;

    // Количество шагов на ячейку (оценка). Установите значение 1, чтобы отключить субциклирование.
    nSubCycle 5;

    // Имя облака для использования
//    cloudName       particleTracks;

    // Seeding method.
    seedSampleSet
    {
        type        boundaryRandom;
        patches     (inlet);
        nPoints     100;
        axis        y;
    }

