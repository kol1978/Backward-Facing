FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 300;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      nonuniform List<scalar> 0();
        value           nonuniform List<scalar> 0();
    }
    upperWall
    {
        type            fixedValue;
        value           uniform 300;
    }
    lowerWall
    {
        type            fixedValue;
        value           nonuniform List<scalar> 0();
    }
    frontAndBack
    {
        type            empty;
    }
    procBoundary2to0
    {
        type            processor;
        value           uniform 300;
    }
    procBoundary2to3
    {
        type            processor;
        value           uniform 300;
    }
}


