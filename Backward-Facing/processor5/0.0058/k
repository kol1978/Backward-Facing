FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0.0058";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   nonuniform List<scalar> 0();

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           nonuniform List<scalar> 0();
    }
    outlet
    {
        type            inletOutlet;
        inletValue      nonuniform List<scalar> 0();
        value           nonuniform List<scalar> 0();
    }
    upperWall
    {
        type            fixedValue;
        value           nonuniform List<scalar> 0();
    }
    lowerWall
    {
        type            fixedValue;
        value           nonuniform List<scalar> 0();
    }
    frontAndBack
    {
        type            empty;
    }
}


