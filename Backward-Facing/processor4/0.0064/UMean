FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0.0064";
    object      UMean;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   nonuniform List<vector> 0();

boundaryField
{
    inlet
    {
        type            calculated;
        value           nonuniform List<vector> 0();
    }
    outlet
    {
        type            calculated;
        value           nonuniform List<vector> 0();
    }
    upperWall
    {
        type            calculated;
        value           nonuniform List<vector> 0();
    }
    lowerWall
    {
        type            calculated;
        value           nonuniform List<vector> 0();
    }
    frontAndBack
    {
        type            empty;
    }
}


