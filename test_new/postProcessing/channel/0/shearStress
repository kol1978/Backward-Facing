FoamFile
{
    format      ascii;
    class       surfaceVectorField;
    location    "0";
    object      shearStress;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   nonuniform List<vector> 0();

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform (-0 -0 -0);
    }
    outlet
    {
        type            calculated;
        value           uniform (-0 -0 -0);
    }
    walls
    {
        type            calculated;
        value           uniform (0.09969565136 -0 -0);
    }
    frontAndBack
    {
        type            empty;
    }
}


