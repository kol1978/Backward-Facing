FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0.1";
    object      U.air2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    boundary
    {
        type            empty;
    }
}

sources
{
    airSource
    {
        type            uniformFixedValue;
        uniformValue    
        {
            type            constant;
            value           (0 0 0);
        }
    }
}


// ************************************************************************* //
