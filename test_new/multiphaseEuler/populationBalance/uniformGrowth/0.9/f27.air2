FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0.9";
    object      f27.air2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField   uniform 0.0117186973725;

boundaryField
{
    boundary
    {
        type            empty;
    }
}

sources
{
    airSource
    {
        type            uniformGrowthSizeGroup;
        libs            1("libuniformGrowth.so");
    }
}


