FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0.7";
    object      rho.air2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 1.15862299395;

boundaryField
{
    boundary
    {
        type            empty;
    }
}


