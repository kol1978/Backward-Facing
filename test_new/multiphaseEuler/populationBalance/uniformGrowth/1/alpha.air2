FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "1";
    object      alpha.air2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField   uniform 0.329207262179;

boundaryField
{
    boundary
    {
        type            empty;
    }
}


