internalField   nonuniform List<scalar> 
0
;

boundaryField
{
    walls
    {
        type            calculated;
    }
    open
    {
        type            calculated;
    }
    frontAndBack
    {
        type            empty;
    }
    procBoundary0to1
    {
        type            processor;
    }
    procBoundary0to2
    {
        type            processor;
    }
}

sources
{
    pointInjection
    {
        type            NaN;
    }
}


