FoamFile
{
    format      binary;
    class       LagrangianVectorField;
    location    "0/Lagrangian/kinematicParcel_functionObject";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   nonuniform List<vector> 
0
;

boundaryField
{
    walls
    {
        type            reboundVelocity;
        e               0.97;
        mu              0.09;
    }
    open
    {
        type            escapeVelocity;
    }
    frontAndBack
    {
        type            empty;
    }
    procBoundary2to0
    {
        type            processor;
    }
    procBoundary2to3
    {
        type            processor;
    }
}

sources
{
    pointInjection
    {
        type            coneVelocity;
        Umean           ( 1 0 0 );
        thetaInner      0 [ deg];
        thetaOuter      5 [ deg];
    }
}


