FoamFile
{
    format      binary;
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

5
(
    walls
    {
        type            wall;
        inGroups        List<word> 1(wall);
        nFaces          10;
        startFace       180;
    }
    open
    {
        type            patch;
        nFaces          10;
        startFace       190;
    }
    frontAndBack
    {
        type            empty;
        inGroups        List<word> 1(empty);
        nFaces          200;
        startFace       200;
    }
    procBoundary3to1
    {
        type            processor;
        inGroups        List<word> 1(processor);
        nFaces          10;
        startFace       400;
        matchTolerance  0.0001;
        myProcNo        3;
        neighbProcNo    1;
    }
    procBoundary3to2
    {
        type            processor;
        inGroups        List<word> 1(processor);
        nFaces          10;
        startFace       410;
        matchTolerance  0.0001;
        myProcNo        3;
        neighbProcNo    2;
    }
)

