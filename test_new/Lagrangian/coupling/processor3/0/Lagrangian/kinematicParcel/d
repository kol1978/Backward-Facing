FoamFile
{
    format      binary;
    class       LagrangianScalarField;
    location    "0/Lagrangian/kinematicParcel";
    object      d;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   nonuniform List<scalar> 
0
;

boundaryField
{
    walls
    {
        type            calculated;
    }
    open
    {
        type            calculated;
    }
    frontAndBack
    {
        type            empty;
    }
    procBoundary3to1
    {
        type            processor;
    }
    procBoundary3to2
    {
        type            processor;
    }
}

sources
{
    pointInjection
    {
        type            distributionDiameter;
        distribution
        {
            type            RosinRammler;
            Q               0;
            min             0.1 [ mm];
            max             1.5 [ mm];
            d               1.4 [ mm];
            n               2 [ ];
        }
    }
}


