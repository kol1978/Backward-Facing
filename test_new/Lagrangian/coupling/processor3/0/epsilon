FoamFile
{
    format      binary;
    class       volScalarField;
    location    "0";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 4.71670589e-05;

boundaryField
{
    walls
    {
        type            epsilonWallFunction;
        value           uniform 4.71670589e-05;
    }
    open
    {
        type            inletOutlet;
        inletValue      uniform 4.71670589e-05;
        value           uniform 4.71670589e-05;
    }
    frontAndBack
    {
        type            empty;
    }
    procBoundary3to1
    {
        type            processor;
        value           uniform 4.71670589e-05;
    }
    procBoundary3to2
    {
        type            processor;
        value           uniform 4.71670589e-05;
    }
}


