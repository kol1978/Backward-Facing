FoamFile
{
    format      binary;
    class       LagrangianScalarField;
    location    "2/Lagrangian/parabolic";
    object      d;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform 0.001;

boundaryField
{
    walls
    {
        type            calculated;
    }
    frontAndBack
    {
        type            empty;
    }
}

sources
{
    pointInjection
    {
        type            uniformFixedValue;
        uniformValue    
        {
            type            constant;
            value           0.001;
        }
    }
}


