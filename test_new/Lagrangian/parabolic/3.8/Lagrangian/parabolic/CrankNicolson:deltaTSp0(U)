FoamFile
{
    format      binary;
    class       LagrangianScalarField;
    location    "3.8/Lagrangian/parabolic";
    object      CrankNicolson:deltaTSp0(U);
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 3 0 0 0 0 0];

internalField   uniform 5.23599e-10;

boundaryField
{
    walls
    {
        type            calculated;
    }
    frontAndBack
    {
        type            empty;
    }
}

sources
{
    pointInjection
    {
        type            NaN;
    }
}


