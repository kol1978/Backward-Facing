FoamFile
{
    format      binary;
    class       LagrangianVectorField;
    location    "4.6/Lagrangian/parabolic";
    object      CrankNicolson:S0(U);
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 4 -2 0 0 0 0];

internalField   uniform (0 5.13034e-09 0);

boundaryField
{
    walls
    {
        type            calculated;
    }
    frontAndBack
    {
        type            empty;
    }
}

sources
{
    pointInjection
    {
        type            NaN;
    }
}


