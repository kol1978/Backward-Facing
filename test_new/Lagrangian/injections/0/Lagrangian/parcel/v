FoamFile
{
    format      binary;
    class       LagrangianScalarField;
    location    "0/Lagrangian/parcel";
    object      v;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 3 0 0 0 0 0];

internalField   nonuniform List<scalar> 
0
;

boundaryField
{
    inlet
    {
        type            calculated;
    }
    outlet
    {
        type            calculated;
    }
    bottom
    {
        type            calculated;
    }
    top
    {
        type            calculated;
    }
    frontAndBack
    {
        type            empty;
    }
}

sources
{
    manualInjection
    {
        type            volume;
    }
}


