FoamFile
{
    format      binary;
    class       LagrangianScalarField;
    location    "0.04/Lagrangian/parcel";
    object      rho;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 1002;

boundaryField
{
    inlet
    {
        type            calculated;
    }
    outlet
    {
        type            calculated;
    }
    bottom
    {
        type            calculated;
    }
    top
    {
        type            calculated;
    }
    frontAndBack
    {
        type            empty;
    }
}

sources
{
    manualInjection
    {
        type            uniformFixedValue;
        uniformValue    
        {
            type            constant;
            value           1002;
        }
    }
}


